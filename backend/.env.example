# ---------------------------------------------------------------------------
# GraphHopper Routing API key.
# Get a free key at https://www.graphhopper.com/ (Dashboard -> API Keys).
# Paste your key on the line below. Leave it empty to run with the built-in
# straight-line mock (the app still works end-to-end without a key).
# ---------------------------------------------------------------------------
GRAPHHOPPER_API_KEY=

# Routing profile. Free tier supports: car, bike, foot.
# The "truck" profile requires a paid GraphHopper plan.
GRAPHHOPPER_PROFILE=car

# Django settings
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
# Comma separated list of allowed hosts (no scheme).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Comma separated list of allowed CORS origins for the React frontend.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
