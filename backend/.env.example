# ---------------------------------------------------------------------------
# OpenRouteService API key.
# Get a free key at https://openrouteservice.org/dev/#/signup
# Paste your key on the line below (leave the app running with the mock
# fixture fallback until you add it).
# ---------------------------------------------------------------------------
ORS_API_KEY=

# Django settings
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
# Comma separated list of allowed hosts (no scheme).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Comma separated list of allowed CORS origins for the React frontend.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
